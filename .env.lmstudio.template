# Aeon-V1 LM Studio environment template
#
# Use this as the starting point for a local .env file when running Aeon-V1
# with LM Studio's OpenAI-compatible server.
#
# Replace the model values below with the exact model IDs shown in LM Studio.
# You can use the same model for all three roles, or split them by purpose:
# - AEON_V1_LLM_CHAT_MODEL: fast interactive chat model
# - AEON_V1_LLM_MODEL: general reflection/simulation model
# - AEON_V1_LLM_DEEP_MODEL: slower/deeper reasoning model

AEON_V1_LLM=1
AEON_V1_LLM_PROVIDER=lmstudio

# Generic/default LM Studio server URL.
AEON_V1_LLM_BASE_URL=http://localhost:1234/v1

# Swap these for any LM Studio model IDs.
AEON_V1_LLM_CHAT_MODEL=your-fast-chat-model-id
AEON_V1_LLM_MODEL=your-general-model-id
AEON_V1_LLM_DEEP_MODEL=your-deep-reasoning-model-id

# Generation and timeout settings.
AEON_V1_LLM_MAX_TOKENS=700
AEON_V1_LLM_TIMEOUT=120
AEON_V1_LLM_CHAT_TIMEOUT=35
AEON_V1_LLM_MAX_ATTEMPTS=2
AEON_V1_LLM_REASONING_EFFORT=low

# Set to 1 if your LM Studio model supports OpenAI-style tool calling well.
# When enabled, reflection/simulation can query Aeon's memory index directly.
AEON_V1_LLM_TOOL_CALLING=0
