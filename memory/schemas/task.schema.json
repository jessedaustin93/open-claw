{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task",
  "description": "An operational task derived from a reflection's suggested_tasks list.",
  "type": "object",
  "required": ["id", "title", "description", "source_reflection_id", "created_at", "status", "priority", "confidence"],
  "properties": {
    "id":                       { "type": "string", "description": "8-character UUID prefix" },
    "title":                    { "type": "string", "description": "Short human-readable slug" },
    "description":              { "type": "string", "description": "Full task text" },
    "source_reflection_id":     { "type": "string", "description": "ID of the reflection that generated this task" },
    "source_reflection_title":  { "type": "string" },
    "created_at":               { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["pending", "selected", "simulated", "completed"],
      "description": "Current status — mutated in place; history tracked via decision records"
    },
    "priority":    { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence":  { "type": "number", "minimum": 0, "maximum": 1 },
    "tags":        { "type": "array",  "items": { "type": "string" } },
    "links":       { "type": "array",  "items": { "type": "string" }, "description": "Obsidian wikilinks" }
  }
}
