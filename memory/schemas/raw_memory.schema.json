{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Raw Memory",
  "description": "An exact, unmodified capture of input text. Never summarized or overwritten.",
  "type": "object",
  "required": ["id", "type", "created", "source", "text", "importance", "tags", "links"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Short unique identifier (8-char UUID prefix)"
    },
    "type": {
      "type": "string",
      "const": "raw"
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp"
    },
    "source": {
      "type": "string",
      "description": "Origin label (e.g. 'manual', 'cli', 'agent')"
    },
    "text": {
      "type": "string",
      "description": "The verbatim input — never modified after creation"
    },
    "importance": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Heuristic importance score [0, 1]"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "links": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Obsidian-style wikilinks to related notes"
    }
  },
  "additionalProperties": false
}
